# ============================================================================
# TaskGuard — Exemplo de variáveis de ambiente
#
# Copie este arquivo para `.env` e ajuste os valores. NUNCA versione o `.env`
# real (ele está no .gitignore). Em produção, defina estas variáveis no
# orquestrador / cofre de segredos.
# ============================================================================

# --- Ambiente: development | testing | production ---
FLASK_CONFIG=development

# --- Chave secreta (sessões, CSRF). GERE UMA FORTE EM PRODUÇÃO! ---
# Sugestão para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-de-64-hex

# --- Servidor de desenvolvimento ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# --- Banco de dados (PostgreSQL) ---
# Credenciais do serviço 'db' no docker-compose. Em produção, troque a senha
# e use um cofre de segredos.
POSTGRES_USER=taskguard
POSTGRES_PASSWORD=taskguard
POSTGRES_DB=taskguard
#
# URL de conexão da aplicação. No Docker Compose, o host é o serviço 'db';
# rodando localmente (fora do compose) aponte para 'localhost'.
#   Compose : postgresql+psycopg://taskguard:taskguard@db:5432/taskguard
#   Local   : postgresql+psycopg://taskguard:taskguard@localhost:5432/taskguard
# Para um teste rápido sem Postgres, ainda é possível usar SQLite:
#   DATABASE_URL=sqlite:///logs/taskguard.db
DATABASE_URL=postgresql+psycopg://taskguard:taskguard@localhost:5432/taskguard

# --- Sessão ---
SESSION_LIFETIME_MINUTES=30
# Em produção (HTTPS) deve ser true:
SESSION_COOKIE_SECURE=false
FORCE_HTTPS=false

# --- Proteção contra brute force ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Rate limiting ---
# Em produção, use um backend compartilhado, ex.: redis://redis:6379
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per hour

# --- Logging / Syslog ---
LOG_LEVEL=INFO
SYSLOG_ENABLED=false
SYSLOG_HOST=localhost
SYSLOG_PORT=514
